  "name": "Oldman's Gruvbox Dark Theme",
  "semanticClass": "theme.dark",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "annotation": {
      "bold": false,
      "foreground": "#b16286"
    },
    "annotationMember": {
      "bold": false,
      "foreground": "#458588"
    },
    "class": {
      "foreground": "#8ec07c"
    },
    "class.public": {
      "bold": true
    },
    "class.public.importDeclaration": {
      "bold": false
    },
    "class.typeArgument": {
      "bold": true,
      "foreground": "#458588"
    },
    "enum": {
      "foreground": "#8ec07c"
    },
    "enum.public": {
      "bold": true
    },
    "enum.public.importDeclaration": {
      "bold": false
    },
    "enum.typeArgument": {
      "bold": true,
      "foreground": "#458588"
    },
    "function": {
      "bold": false,
      "foreground": "#b8bb26"
    },
    "function.declaration": {
      "bold": true
    },
    "interface": {
      "bold": true,
      "foreground": "#8ec07c"
    },
    "interface.generic": {
      "bold": false
    },
    "interface.public": {
      "bold": true
    },
    "interface.public.importDeclaration": {
      "bold": false
    },
    "interface.typeArgument": {
      "bold": false,
      "foreground": "#458588"
    },
    "keyword.documentation": {
      "bold": false,
      "foreground": "#689d6a"
    },
    "modifier": {
      "bold": false,
      "foreground": "#d65d0e"
    },
    "namespace": {
      "bold": false,
      "foreground": "#427b58"
    },
    "parameter": {
      "bold": false,
      "foreground": "#83a598"
    },
    "parameter.declaration": {
      "bold": true
    },
    "property": {
      "bold": true,
      "foreground": "#98971a"
    },
    "variable": {
      "bold": false,
      "foreground": "#83a598"
    },
    "variable.declaration": {
      "bold": true
    }
  },
  "tokenColors": [
    {
      "scope": "string.quoted",
      "settings": {
        "foreground": "#d79921"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#8ec07c"
      }
    },
    {
      "scope": [
        "keyword.other.import",
        "keyword.other.package",
        "keyword.control.import"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#689d6a"
      }
    },
    {
      "scope": [
        "meta.member.access"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#83a598"
      }
    },
    {
      "scope": [
        "meta.function-call.generic"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#83a598"
      }
    },
    {
      "scope": [
        "meta.function-call.arguments"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#83a598"
      }
    },
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#7c6f64"
      }
    },
    {
      "scope": [
        "storage.modifier.import",
        "storage.modifier.package"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#427b58"
      }
    },
    {
      "scope": [
        "source.sql"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#8ec07c"
      }
    },
    {
      "scope": [
        "source.sql keyword.other"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#fe8019"
      }
    },
    {
      "scope": [
        "source.sql support.function"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#b8bb26"
      }
    },
    {
      "scope": [
        "meta.map.key entity.name"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#b8bb26"
      }
    },
    {
      "scope": [
        "source.yaml",
        "meta.map.value entity.name"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#b8bb26"
      }
    },
    {
      "scope": [
        "meta.map.value constant"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#83a598"
      }
    }
  ],
  "type": "dark"
}
